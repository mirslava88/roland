{
  "name": "presentation-display-manager",
  "version": "1.0.0",
  "description": "Cross-platform app for seamless switching between presentations, videos, and PDFs on a secondary display",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-vite build && electron-builder",
    "package:win": "electron-vite build && electron-builder --win",
    "package:mac": "electron-vite build && electron-builder --mac"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "pdfjs-dist": "^4.9.155",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^35.7.5",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "postcss": "^8.4.49",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "com.roland.presentation-display-manager",
    "productName": "Presentation Display Manager",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "!**/*.map"
    ],
    "extraResources": [
      {
        "from": "scripts",
        "to": "scripts",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "forceCodeSigning": false,
    "mac": {
      "target": [
        "dmg"
      ]
    }
  }
}
